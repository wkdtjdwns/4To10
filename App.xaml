<Application x:Class="FourTen.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

        <!-- 색상 -->
        <Color x:Key="SkyTopColor">#0B1E38</Color>
        <Color x:Key="SkyMidColor">#274B6D</Color>
        <Color x:Key="SkyHorizonColor">#4E7A9E</Color>
        <Color x:Key="GroundColor">#070B12</Color>

        <SolidColorBrush x:Key="GroundBrush" Color="#070B12"/>
        <SolidColorBrush x:Key="MountainBrush" Color="#0E1826"/>
        <SolidColorBrush x:Key="TextBrush" Color="#DCE6F0"/>
        <SolidColorBrush x:Key="DimTextBrush" Color="#6E8199"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#5AC8E0"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#5FD08A"/>

        <FontFamily x:Key="AppFont">Segoe UI</FontFamily>

        <!-- 밤하늘 그라데이션 -->
        <LinearGradientBrush x:Key="SkyBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{StaticResource SkyTopColor}" Offset="0.0"/>
            <GradientStop Color="{StaticResource SkyMidColor}" Offset="0.42"/>
            <GradientStop Color="{StaticResource SkyHorizonColor}" Offset="0.62"/>
        </LinearGradientBrush>

        <!-- 하단 팔레트 기호 버튼 -->
        <Style x:Key="PaletteButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource DimTextBrush}"/>
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize" Value="34"/>
            <Setter Property="FontWeight" Value="Light"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="58"/>
            <Setter Property="Height" Value="58"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1AFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 아이콘 버튼(햄버거, 리셋, 힌트 등) -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 힌트 패널 버튼 -->
        <Style x:Key="HintButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Light"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="#17304A" CornerRadius="12"
                                Padding="16,13" BorderBrush="#294863" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#244A6E"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#5AC8E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Application.Resources>
</Application>
